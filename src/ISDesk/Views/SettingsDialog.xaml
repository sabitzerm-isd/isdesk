<Window x:Class="ISDesk.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ISDesk – Optionen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Width="400" SizeToContent="Height">

    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="#CCFFFFFF" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBlock" x:Key="SectionStyle">
            <Setter Property="Foreground" Value="#88FFFFFF" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,14,0,6" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Foreground" Value="#F2FFFFFF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6" Background="#28FFFFFF" Padding="10,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3CFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsDefaulted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A6EA5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Optionen"
                   Foreground="#EEFFFFFF" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4" />

        <!-- Bereich -->
        <TextBlock Grid.Row="1" Text="BEREICH" Style="{StaticResource SectionStyle}" />
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
                <RowDefinition Height="32" />
                <RowDefinition Height="32" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Titel" Style="{StaticResource LabelStyle}" />
            <TextBox Grid.Row="0" Grid.Column="1" Height="28" Padding="6,3" FontSize="13"
                     VerticalAlignment="Center" VerticalContentAlignment="Center"
                     Background="#22000000" Foreground="White"
                     BorderBrush="#40FFFFFF" BorderThickness="1" CaretBrush="White"
                     Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Icon-Größe" Style="{StaticResource LabelStyle}" />
            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="IconSizeBox"
                      Width="110" Height="28" HorizontalAlignment="Left" VerticalAlignment="Center"
                      SelectionChanged="IconSize_SelectionChanged">
                <ComboBoxItem Content="Klein (24)" Tag="24" />
                <ComboBoxItem Content="Mittel (32)" Tag="32" />
                <ComboBoxItem Content="Groß (48)" Tag="48" />
            </ComboBox>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Transparenz" Style="{StaticResource LabelStyle}" />
            <Slider Grid.Row="2" Grid.Column="1" Minimum="0.1" Maximum="1.0"
                    VerticalAlignment="Center"
                    Value="{Binding Opacity, Mode=TwoWay}" />

            <CheckBox Grid.Row="3" Grid.Column="1" Content="Hintergrund-Blur"
                      Foreground="#DDFFFFFF" FontSize="12.5" VerticalAlignment="Center"
                      IsChecked="{Binding Blur, Mode=TwoWay}" />
        </Grid>

        <!-- Sicherung -->
        <TextBlock Grid.Row="3" Text="SICHERUNG (ALLE BEREICHE)" Style="{StaticResource SectionStyle}" />
        <TextBlock Grid.Row="4" Foreground="#99FFFFFF" FontSize="11.5" TextWrapping="Wrap"
                   Text="Sichert die Konfiguration und alle Bereichs-Ordner in eine ZIP-Datei – z. B. bevor der Rechner neu aufgesetzt wird." />
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Sicherung erstellen…" Click="CreateBackup_Click" />
            <Button Content="Sicherung wiederherstellen…" Click="RestoreBackup_Click" />
        </StackPanel>

        <!-- Fusszeile -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,16,0,0">
            <Button Content="Ordner im Explorer öffnen" Click="OpenFolder_Click" />
        </StackPanel>
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Schließen" IsDefault="True" IsCancel="True" Margin="0" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
