<Window x:Class="ISDesk.Views.UpdateBanner"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ISDesk-Update"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        Width="360">

    <Border Background="#F21B1E26" CornerRadius="10" BorderBrush="#3A6EA5" BorderThickness="1" Padding="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.5" Color="Black" />
        </Border.Effect>
        <StackPanel>
            <TextBlock x:Name="TitleText" Foreground="#F2FFFFFF" FontSize="14" FontWeight="SemiBold"
                       TextWrapping="Wrap" Text="Update verfügbar" />
            <TextBlock x:Name="InfoText" Foreground="#AACCEEFF" FontSize="12" Margin="0,4,0,12"
                       TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Später" Click="Later_Click" Margin="0,0,8,0" MinWidth="80" Height="28"
                        Foreground="#F2FFFFFF" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="6" Background="#28FFFFFF" Padding="10,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#3CFFFFFF" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="InstallButton" Content="Jetzt installieren" Click="Install_Click" MinWidth="120" Height="28"
                        Foreground="White" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="6" Background="#3A6EA5" Padding="10,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#4A82C0" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
