<Window x:Class="ISDesk.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ISDesk"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Width="340" SizeToContent="Height">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Foreground" Value="#F2FFFFFF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6" Background="#28FFFFFF" Padding="10,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3CFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsDefaulted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A6EA5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#F21B1E26" Padding="18">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText" Grid.Row="0"
                   Foreground="#EEFFFFFF" FontSize="13" Margin="0,0,0,10"
                   TextWrapping="Wrap" />

        <TextBox x:Name="Input" Grid.Row="1"
                 Height="30" Padding="8,4" FontSize="13"
                 Background="#22000000" Foreground="White"
                 BorderBrush="#40FFFFFF" BorderThickness="1"
                 CaretBrush="White" VerticalContentAlignment="Center" />

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Abbrechen" IsCancel="True" Click="Cancel_Click" />
            <Button Content="OK" IsDefault="True" Click="Ok_Click" />
        </StackPanel>
    </Grid>
    </Border>
</Window>
