<Window x:Class="ISDesk.Views.FenceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="CanResize"
        WindowStartupLocation="Manual"
        MinWidth="180" MinHeight="120"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Icon-Kachel: Bild + Name -->
        <DataTemplate x:Key="IconItemTemplate">
            <StackPanel Width="84" Margin="2,4" Background="Transparent">
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Öffnen" Click="IconOpen_Click" />
                        <MenuItem Header="Im Explorer anzeigen" Click="IconShowInExplorer_Click" />
                        <MenuItem Header="Umbenennen…" Click="IconRename_Click" />
                        <Separator />
                        <MenuItem Header="In den Papierkorb" Click="IconRecycle_Click" />
                    </ContextMenu>
                </StackPanel.ContextMenu>
                <Image Source="{Binding Icon}" Width="32" Height="32"
                       HorizontalAlignment="Center" Margin="0,4"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Text="{Binding DisplayName}" FontSize="11"
                           Foreground="#F2FFFFFF"
                           TextAlignment="Center" HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxHeight="30">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.6" Color="Black" />
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <!-- Icon-Container: Hover/Selektion, kein Fokus-Rechteck -->
        <Style x:Key="IconItemContainerStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab -->
        <DataTemplate x:Key="TabItemTemplate">
            <Border MouseLeftButtonDown="Tab_Click" CornerRadius="6" Padding="10,3" Margin="2,0,0,0" Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#18FFFFFF" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Background" Value="#2EFFFFFF" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Umbenennen…" Click="RenameTab_Click" />
                        <MenuItem Header="Tab entfernen" Click="RemoveTab_Click" IsEnabled="{Binding CanRemove}" />
                    </ContextMenu>
                </Border.ContextMenu>
                <TextBlock Text="{Binding Title}" FontSize="11.5" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#CCFFFFFF" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </DataTemplate>

        <!-- "+"-Button: nur bei Maus ueber dem Fenster sichtbar -->
        <Style x:Key="AddTabButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Foreground" Value="#DDFFFFFF" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="34" />
            <RowDefinition Height="28" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Titelzeile: Ziehen zum Verschieben -->
        <Border Grid.Row="0" Background="#26000000"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <TextBlock Text="{Binding Title}"
                       FontWeight="SemiBold" FontSize="12.5"
                       Foreground="#DDFFFFFF"
                       VerticalAlignment="Center" Margin="12,0"
                       TextTrimming="CharacterEllipsis" />
        </Border>

        <!-- Tab-Leiste -->
        <DockPanel Grid.Row="1" Margin="6,1,6,1" LastChildFill="True">
            <Button DockPanel.Dock="Right" Content="+" Style="{StaticResource AddTabButtonStyle}"
                    Click="AddTab_Click" ToolTip="Neuen Tab anlegen" />
            <ItemsControl ItemsSource="{Binding Tabs}" ItemTemplate="{StaticResource TabItemTemplate}"
                          VerticalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </DockPanel>

        <!-- Inhalt: Icon-Raster des aktiven Tabs -->
        <ListBox Grid.Row="2" x:Name="IconList"
                 ItemsSource="{Binding ActiveTab.Items}"
                 ItemTemplate="{StaticResource IconItemTemplate}"
                 ItemContainerStyle="{StaticResource IconItemContainerStyle}"
                 Background="Transparent" BorderThickness="0"
                 Padding="4"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 VirtualizingPanel.IsVirtualizing="False"
                 HorizontalContentAlignment="Stretch"
                 MouseDoubleClick="IconList_MouseDoubleClick"
                 PreviewMouseLeftButtonDown="IconList_PreviewMouseLeftButtonDown"
                 MouseMove="IconList_MouseMove">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Neuer Tab" Click="AddTab_Click" />
                    <MenuItem Header="Bereich umbenennen…" Click="RenameFence_Click" />
                    <Separator />
                    <MenuItem StaysOpenOnClick="True">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal" Width="210">
                                <TextBlock Text="Transparenz" VerticalAlignment="Center" Width="82" />
                                <Slider Minimum="0.1" Maximum="1.0" Width="120" VerticalAlignment="Center"
                                        Value="{Binding Opacity, Mode=TwoWay}" />
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Header="Hintergrund-Blur" IsCheckable="True" IsChecked="{Binding Blur, Mode=TwoWay}" />
                    <Separator />
                    <MenuItem Header="Ordner im Explorer öffnen" Click="OpenFolder_Click" />
                    <MenuItem Header="Neuer Bereich" Click="NewFence_Click" />
                    <MenuItem Header="Bereich entfernen…" Click="RemoveFence_Click" />
                    <Separator />
                    <MenuItem Header="ISDesk beenden" Click="ExitApp_Click" />
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
    </Grid>
</Window>
