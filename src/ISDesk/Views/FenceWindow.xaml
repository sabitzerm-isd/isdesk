<Window x:Class="ISDesk.Views.FenceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="CanResize"
        WindowStartupLocation="Manual"
        MinWidth="180" MinHeight="120"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="34" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Titelzeile: Ziehen zum Verschieben -->
        <Border Grid.Row="0" Background="#26000000"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <TextBlock Text="{Binding Title}"
                       FontWeight="SemiBold" FontSize="12.5"
                       Foreground="#DDFFFFFF"
                       VerticalAlignment="Center" Margin="12,0"
                       TextTrimming="CharacterEllipsis" />
        </Border>

        <!-- Inhalt (Tabs/Icons folgen in spaeteren Tasks) -->
        <Grid Grid.Row="1" x:Name="ContentRoot" />
    </Grid>
</Window>
